# Token de validation pour la modération (Thomas uniquement)
# Générer avec: openssl rand -hex 32
ADMIN_TOKEN=your_secret_token_here

# Clé API Resend pour les emails de notification
# Créer un compte sur https://resend.com (free tier: 3000 emails/mois)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Token Vercel Blob Storage (généré automatiquement par Vercel)
# NE PAS créer manuellement — ajouter Vercel Blob via le dashboard Vercel
# Dashboard: https://vercel.com/dashboard → ton projet → Storage → Add Blob Store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Email de Thomas pour recevoir les notifications de soumissions communautaires
ADMIN_EMAIL=thomas@example.com
